# Local config holds real secrets — never commit it. Use config.example.toml.
/config.toml
/agent.toml

# Real deployment compose (host paths, hostnames) — never commit it. The tracked
# template is docker-compose.example.yml.
/docker-compose.yml

# compose .env (interpolated secrets: tokens, CF service token)
/.env

# embedded state db (bbolt) — holds encrypted registry creds + stack specs; a
# stray local copy must never be committed
*.db
/data/

# air build output
/tmp/

# compiled binaries
/hope
/hope-boot
/cmd/hope/hope

# example plugin binaries (go build output; name == module dir)
/examples/plugins/hello-world/hello-world
/examples/plugins/hope-postgres/hope-postgres

# go workspace / vendor (sov is a normal module, fetched on build)
/vendor/
go.work
go.work.sum

# playwright mcp debug artifacts (anywhere)
.playwright-mcp/

# frontend deps + build (see frontend/.gitignore too)
/frontend/node_modules/

# Built SPA: ignore the build output, but keep a placeholder index.html so
# `go:embed all:frontend/dist` compiles without a frontend build.
/frontend/dist/*
!/frontend/dist/index.html

# OS / editor noise
.DS_Store
Thumbs.db
*.log
*.tmp
*~
.idea/
*.swp

# stray root screenshots (debug); docs/ images are tracked
/*.png

# dev-only plugin publish helper (poison-free rebuild+push+recreate)
scripts/dev-publish-ks.sh
